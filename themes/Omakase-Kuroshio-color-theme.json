  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6d757f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "FINAL - Language keywords",
      "scope": [
        "keyword",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.type",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.flow",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.as",
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.import",
        "storage.modifier.import",
        "meta.import storage.type",
        "meta.import keyword.control.type",
        "meta.import storage.modifier",
        "meta.import keyword.control.import",
        "meta.import keyword.control.from",
        "meta.import punctuation.definition.keyword",
        "meta.export keyword",
        "text.html punctuation.definition.tag",
        "text.html punctuation.separator.key-value.html",
        "text.html punctuation.definition.tag.begin",
        "text.html punctuation.definition.tag.end",
        "text.html punctuation.definition.string.begin",
        "text.html punctuation.definition.string.end",
        "meta.tag punctuation.definition.tag",
        "meta.tag punctuation.separator.key-value",
        "punctuation.definition.doctype",
        "punctuation.separator.doctype"
      ],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },
    {
      "name": "FINAL - Primitive and built-in language types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "support.class.builtin",
        "storage.type.primitive",
        "keyword.operator.type"
      ],
      "settings": {
        "foreground": "#B8C4D3"
      }
    },
    {
      "name": "FINAL - JS built-ins and globals",
      "scope": [
        "variable.language",
        "support.class.builtin",
        "support.class.dom",
        "support.variable.dom",
        "support.type.object.dom",
        "support.type.object.console",
        "support.type.object.window",
        "support.type.object.document",
        "support.type.object.math",
        "support.type.object.console.js"
      ],
      "settings": {
        "foreground": "#76D4C3"
      }
    },
    {
      "name": "FINAL - HTML attribute syntax",
      "scope": [
        "text.html entity.other.attribute-name",
        "text.html.basic entity.other.attribute-name",
        "meta.tag entity.other.attribute-name",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx"
      ],
      "settings": {
        "foreground": "#AEBCCD",
        "fontStyle": ""
      }
    },
    {
      "name": "FINAL - Parameters",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "FINAL - Object members",
      "scope": [
        "source.js variable.other.property",
        "source.ts variable.other.property",
        "source.jsx variable.other.property",
        "source.tsx variable.other.property",
        "meta.object-literal.key",
        "meta.object.member variable.other.property",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#C9D7E8"
      }
    },
    {
      "name": "FINAL - Names",
      "scope": [
        "meta.import entity.name.type",
        "meta.import support.class",
        "meta.import support.type",
        "meta.import entity.name.class",
        "meta.import variable.other.readwrite",
        "meta.import variable.other.object",
        "meta.import meta.brace variable.other.readwrite",
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "variable",
        "identifier",
        "support.variable",
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "text.html entity.name.tag",
        "text.html.basic entity.name.tag",
        "entity.name.tag",
        "meta.tag",
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "FINAL - Paths strings and values",
      "scope": [
        "meta.import string",
        "meta.import string.quoted",
        "meta.import punctuation.definition.string.begin",
        "meta.import punctuation.definition.string.end",
        "meta.export string",
        "meta.export string.quoted",
        "meta.export punctuation.definition.string.begin",
        "meta.export punctuation.definition.string.end",
        "text.html string",
        "text.html.basic string",
        "text.html punctuation.definition.string.begin",
        "text.html punctuation.definition.string.end",
        "meta.tag string.quoted",
        "string",
        "markup.inline.raw",
        "string.quoted",
        "string.template",
        "constant",
        "constant.language",
        "constant.numeric",
        "constant.character.escape",
        "source.css constant.language"
      ],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "FINAL - CSS selectors",
      "scope": [
        "source.css entity.other.attribute-name.class",
        "source.scss entity.other.attribute-name.class",
        "source.sass entity.other.attribute-name.class",
        "source.less entity.other.attribute-name.class",
        "source.stylus entity.other.attribute-name.class",
        "source.postcss entity.other.attribute-name.class",
        "source.css entity.other.attribute-name.id",
        "source.scss entity.other.attribute-name.id",
        "source.sass entity.other.attribute-name.id",
        "source.less entity.other.attribute-name.id",
        "source.stylus entity.other.attribute-name.id",
        "source.postcss entity.other.attribute-name.id",
        "source.css entity.name.tag",
        "source.scss entity.name.tag",
        "source.sass entity.name.tag",
        "source.less entity.name.tag",
        "source.stylus entity.name.tag",
        "source.postcss entity.name.tag",
        "source.css entity.other.attribute-name.pseudo-class",
        "source.scss entity.other.attribute-name.pseudo-class",
        "source.sass entity.other.attribute-name.pseudo-class",
        "source.less entity.other.attribute-name.pseudo-class",
        "source.stylus entity.other.attribute-name.pseudo-class",
        "source.postcss entity.other.attribute-name.pseudo-class"
      ],
      "settings": {
        "foreground": "#93BCF4"
      }
    },
    {
      "name": "FINAL - CSS pseudo syntax",
      "scope": [
        "source.css punctuation.definition.entity",
        "source.scss punctuation.definition.entity",
        "source.sass punctuation.definition.entity",
        "source.less punctuation.definition.entity",
        "source.stylus punctuation.definition.entity",
        "source.postcss punctuation.definition.entity",
        "source.css punctuation.separator.key-value",
        "source.scss punctuation.separator.key-value",
        "source.sass punctuation.separator.key-value",
        "source.less punctuation.separator.key-value",
        "source.stylus punctuation.separator.key-value",
        "source.postcss punctuation.separator.key-value",
        "source.css keyword.operator.combinator",
        "source.scss keyword.operator.combinator",
        "source.sass keyword.operator.combinator",
        "source.less keyword.operator.combinator",
        "source.stylus keyword.operator.combinator",
        "source.postcss keyword.operator.combinator"
      ],
      "settings": {
        "foreground": "#AEBCCD"
      }
    },
    {
      "name": "FINAL - CSS properties",
      "scope": [
        "source.css support.type.property-name",
        "source.scss support.type.property-name",
        "source.sass support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#E6EDF5"
      }
    },
    {
      "name": "FINAL - CSS values",
      "scope": [
        "source.css constant.numeric",
        "source.scss constant.numeric",
        "source.sass constant.numeric",
        "source.less constant.numeric",
        "source.stylus constant.numeric",
        "source.postcss constant.numeric",
        "source.css keyword.other.unit",
        "source.scss keyword.other.unit",
        "source.sass keyword.other.unit",
        "source.less keyword.other.unit",
        "source.stylus keyword.other.unit",
        "source.postcss keyword.other.unit",
        "source.css support.constant",
        "source.scss support.constant",
        "source.sass support.constant",
        "source.less support.constant",
        "source.stylus support.constant",
        "source.postcss support.constant",
        "source.css string",
        "source.scss string",
        "source.sass string",
        "source.less string",
        "source.stylus string",
        "source.postcss string"
      ],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Brackets and delimiters",
      "scope": [
        "punctuation.section.block.begin",
        "punctuation.section.block.end",
        "punctuation.section.group.begin",
        "punctuation.section.group.end",
        "punctuation.section.parens.begin",
        "punctuation.section.parens.end",
        "punctuation.section.brackets.begin",
        "punctuation.section.brackets.end",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end",
        "punctuation.definition.arguments.begin",
        "punctuation.definition.arguments.end",
        "punctuation.definition.array.begin",
        "punctuation.definition.array.end",
        "punctuation.definition.block.begin",
        "punctuation.definition.block.end",
        "source.js punctuation.section",
        "source.ts punctuation.section",
        "source.jsx punctuation.section",
        "source.tsx punctuation.section",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#63B9AE"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "meta.brace", "meta.delimiter"],
      "settings": {
        "foreground": "#919ca8"
      }
    },
    {
      "name": "FINAL - HTML text content",
      "scope": [
        "text.html",
        "text.html.basic",
        "text.html.basic source",
        "text.html source",
        "meta.tag.inline.any.html",
        "meta.tag.block.any.html",
        "meta.embedded.block.html"
      ],
      "settings": {
        "foreground": "#E7EDF5"
      }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#8FB8F5"
      }
    },
    {
      "name": "Markdown emphasis",
      "scope": ["markup.bold", "markup.italic"],
      "settings": {
        "foreground": "#c7d1dc"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": {
        "foreground": "#7FE7D0"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": {
        "foreground": "#d46f6f"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#d46f6f"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8FB8F5",
    "class": "#8FB8F5",
    "enum": "#8FB8F5",
    "interface": "#8FB8F5",
    "type": "#8FB8F5",
    "type.defaultLibrary": "#B8C4D3",
    "typeParameter": "#76D4C3",
    "struct": "#8FB8F5",
    "parameter": "#8FB8F5",
    "variable": "#8FB8F5",
    "variable.defaultLibrary": "#76D4C3",
    "property": "#C9D7E8",
    "property.defaultLibrary": "#C9D7E8",
    "enumMember": "#7FE7D0",
    "event": "#8FB8F5",
    "function": "#8FB8F5",
    "method": "#8FB8F5",
    "function.defaultLibrary": "#8FB8F5",
    "macro": "#B8C4D3",
    "keyword": "#B8C4D3",
    "modifier": "#B8C4D3",
    "keyword.defaultLibrary": "#B8C4D3",
    "comment": {
      "foreground": "#6d757f",
      "fontStyle": "italic"
    },
    "string": "#7FE7D0",
    "number": "#7FE7D0",
    "regexp": "#7FE7D0",
    "operator": "#919ca8",
    "decorator": "#76D4C3"
  }
}
